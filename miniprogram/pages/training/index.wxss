/* pages/training/index.wxss */
.intro-wrap {
  min-height: 100vh;
}

.training-page {
  min-height: 100vh;
  background: #1E1C33;
  padding: 180rpx 40rpx 200rpx;
  box-sizing: border-box;
}

.prestart-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 9000;
  background: rgba(30, 28, 51, 0.86);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(16rpx);
}

.prestart-number {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 800;
  color: #FFFFFF;
}

.prestart-lamp {
  width: 520rpx;
  height: 520rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prestart-lamp-outer {
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.prestart-lamp-inner {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.42);
}

.prestart-tip {
  margin-top: 30rpx;
  font-size: 30rpx;
  color: rgba(185, 198, 226, 0.92);
  text-align: center;
  padding: 0 56rpx;
  line-height: 1.6;
}

/* 顶部标题栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
  padding-top: 80rpx;
  padding-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.close-btn {
  font-size: 40rpx;
  color: #FFFFFF;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 计时器模块 */
.timer-section {
  margin-bottom: 120rpx;
}

.progress-ring {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 60rpx;
}

.progress-canvas {
  position: absolute;
  top: 0;
  left: 0;
}

.progress-canvas-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(38, 41, 71, 0.5);
}

.timer-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 10;
}

.timer-text {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 0 30rpx rgba(130, 208, 255, 0.8), 0 0 60rpx rgba(118, 245, 227, 0.6);
  animation: timerGlow 2s ease-in-out infinite;
}

@keyframes timerGlow {
  0%, 100% {
    text-shadow: 0 0 30rpx rgba(130, 208, 255, 0.8), 0 0 60rpx rgba(118, 245, 227, 0.6);
  }
  50% {
    text-shadow: 0 0 50rpx rgba(130, 208, 255, 1), 0 0 100rpx rgba(118, 245, 227, 0.8);
  }
}

.timer-label {
  display: block;
  font-size: 24rpx;
  color: #B9C6E2;
  opacity: 0.8;
}

.timer-text.paused {
  animation: none;
  text-shadow: 0 0 20rpx rgba(130, 208, 255, 0.5), 0 0 40rpx rgba(118, 245, 227, 0.3);
}

/* 数据栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: #262947;
  border-radius: 24rpx;
  padding: 32rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #B9C6E2;
  margin-bottom: 12rpx;
  opacity: 0.8;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #B9C6E2;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #5E678B;
  opacity: 0.6;
}

/* 呼吸引导模块 */
.breathing-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.breathing-indicator {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  margin: 0 auto 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #6ED380 0%, #4CB05D 100%);
  transition: transform ease-in-out, box-shadow 0.3s ease-in-out;
  box-shadow: 0 0 60rpx rgba(110, 211, 128, 0.4);
  will-change: transform;
  transform-origin: center center;
}

.breathing-indicator.inhale {
  background: linear-gradient(180deg, #6ED380 0%, #4CB05D 100%);
  box-shadow: 0 0 60rpx rgba(110, 211, 128, 0.4);
}

.breathing-indicator.exhale {
  background: linear-gradient(180deg, #6ED380 0%, #4CB05D 100%);
  box-shadow: 0 0 40rpx rgba(110, 211, 128, 0.3);
}

.breathing-indicator.hold {
  background: linear-gradient(180deg, #82D0FF 0%, #76F5E3 100%);
  box-shadow: 0 0 50rpx rgba(130, 208, 255, 0.4);
}

.breathing-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.breathing-count {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.breathing-hint {
  font-size: 28rpx;
  color: #B9C6E2;
  opacity: 0.9;
  margin-top: 24rpx;
  transition: opacity 0.3s;
}

/* 右下角：语音 + 说明 */
.fab-stack {
  position: fixed;
  right: 40rpx;
  top:200rpx;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.fab-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(38, 41, 71, 0.9);
  border: 2rpx solid rgba(130, 208, 255, 0.35);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-btn-hover {
  opacity: 0.85;
}

.fab-btn-icon {
  width: 56rpx;
  height: 56rpx;
}

/* 说明图弹层（打开时 canvas 已卸掉，用普通 view 即可全屏盖住并正常显示本地图） */
.intro-pop-root {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.intro-pop-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  background-color: rgba(0, 0, 0, 0.55);
}

.intro-pop-panel {
  position: relative;
  z-index: 1;
  width: 640rpx;
  max-width: 100%;
  max-height: 85vh;
  background-color: #262947;
  border-radius: 24rpx;
  border: 2rpx solid rgba(130, 208, 255, 0.25);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.35);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.intro-pop-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 2;
  width: 66rpx;
  height: 66rpx;
  line-height: 66rpx;
  text-align: center;
  font-size: 48rpx;
  color: #B9C6E2;
  border-radius:33rpx;
  background-color: rgba(30, 28, 51, 0.95);
  border: 1rpx solid rgba(130, 208, 255, 0.3);
}

.intro-pop-scroll {
  width: 100%;
  height: 62vh;
  max-height: 80vh;
  padding: 112rpx 34rpx 32rpx;
  box-sizing: border-box;
}

.intro-pop-img {
  width: 100%;
  display: block;
  border-radius: 12rpx;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 32rpx;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #1E1C33;
}

.action-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.pause-btn {
  background: linear-gradient(135deg, #FBB46F 0%, #E88E53 100%);
  box-shadow: 0 4rpx 20rpx rgba(251, 180, 111, 0.3);
}

.pause-btn.resume {
  background: linear-gradient(135deg, #FBB46F 0%, #E88E53 100%);
}

.stop-btn {
  background: linear-gradient(135deg, #F2939B 0%, #E26678 100%);
  box-shadow: 0 4rpx 20rpx rgba(242, 147, 155, 0.3);
}
