  box-shadow: 0 4rpx 20rpx rgba(94, 200, 255, 0.3);
  padding: 0;
}
.intro-pop-root {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 9999;
}
.intro-pop-mask {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.6);
}
.intro-pop-panel {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-height: 70vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.intro-pop-scroll {
  max-height: 65vh;
}
.intro-pop-img {
  width: 100%;
}