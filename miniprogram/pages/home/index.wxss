/* 安全须知弹窗 */
.safety-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  padding: 40rpx;
  box-sizing: border-box;
}

.safety-modal.show {
  display: flex;
}

.safety-modal-content {
  width: 100%;
  max-width: 680rpx;
  max-height: 85vh;
  background: linear-gradient(180deg, #ECF5F8 0%, #D0F3E4 100%);
  border-radius: 32rpx;
  padding: 48rpx 40rpx 48rpx;
  box-sizing: border-box;
  overflow-y: auto;
  position: relative;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.safety-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2D3962;
  text-align: center;
  margin-bottom: 36rpx;
}

.safety-warning-box {
  background: #FEE597;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: flex-start;
}

.safety-warning-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 24rpx;
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.safety-warning-triangle {
  width: 0;
  height: 0;
  border-left: 32rpx solid transparent;
  border-right: 32rpx solid transparent;
  border-bottom: 56rpx solid #000;
  position: absolute;
  top: 0;
  left: -2rpx;
}

.safety-warning-triangle::after {
  content: '';
  position: absolute;
  top: 2rpx;
  left: -30rpx;
  width: 0;
  height: 0;
  border-left: 30rpx solid transparent;
  border-right: 30rpx solid transparent;
  border-bottom: 52rpx solid #FFCC00;
}

.safety-warning-exclamation {
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
  z-index: 2;
}

.safety-warning-text {
  flex: 1;
  font-size: 28rpx;
  color: #2D3962;
  line-height: 1.6;
}

.safety-content-card {
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
}

.safety-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.safety-icon-circle {
  width: 56rpx;
  height: 56rpx;
