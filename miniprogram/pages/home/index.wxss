/* 吸气按钮 - 深蓝渐变 */
.rhythm-inhale {
  background: linear-gradient(180deg, rgba(50, 77, 122, 1.1) 0%, #324D7A 100%);
  color: #FFFFFF;
  border-radius: 70rpx 0 0 70rpx;
  padding-left: 44rpx;
  padding-right: 40rpx;
  position: relative;
}

.rhythm-inhale::after {
  content: '';
  position: absolute;
  right: -24rpx;
  top: 0;
  width: 0;
  height: 0;
  border-top: 70rpx solid transparent;
  border-bottom: 70rpx solid transparent;
  border-left: 24rpx solid #324D7A;
  z-index: 0;
}

/* 呼气按钮 - 青绿色渐变（teal/mint green） */
.rhythm-exhale {
  background: linear-gradient(180deg, rgba(114, 175, 255, 1.1) 0%, #72AFFF 100%);
  color: #FFFFFF;
  margin-left: -24rpx;
  margin-right: -24rpx;
  padding-left: 44rpx;
  padding-right: 44rpx;
  position: relative;
  z-index: 1;
}

.rhythm-exhale::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 0;
  height: 0;
  border-top: 70rpx solid transparent;
  border-bottom: 70rpx solid transparent;
  border-left: 24rpx solid #324D7A;
  z-index: 0;
}

.rhythm-exhale::after {
  content: '';
  position: absolute;
  right: -24rpx;
  top: 0;
  width: 0;
  height: 0;
  border-top: 70rpx solid transparent;
  border-bottom: 70rpx solid transparent;
  border-left: 24rpx solid #72AFFF;
  z-index: 0;
}

/* 保持按钮 - 粉红渐变 */
