}

/* 粒子效果容器 */
.particles-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  will-change: transform, opacity;
  transform-origin: center center;
  animation: particleFloat infinite;
}

/* 有初始分散距离的粒子：先快速分散（100ms），然后正常动画 */
.particle-initial {
  animation: particleQuickSpread 0.1s ease-out forwards, particleFloat infinite;
  /* 快速分散立即开始，正常动画在快速分散完成后开始（延迟在JS中通过item.delay设置） */
  animation-delay: 0s, var(--delay, 0.1s);
}

/* 快速分散动画（100ms），带渐隐淡入效果 */
@keyframes particleQuickSpread {
  0% {
    transform: translate(0, 0) scale(1);
    opacity: 0; /* 开始时完全透明 */
  }
  50% {
    opacity: 0.5; /* 中间阶段半透明 */
  }
  100% {
    transform: translate(var(--initial-dx, 0), var(--initial-dy, 0)) scale(1);
    opacity: 0.9; /* 分散完成后完全显示 */
  }
}

/* 粒子动画：先快速分散，然后继续扩散并逐渐消失 */
@keyframes particleFloat {
  0% {
    /* 从快速分散后的位置开始，保持透明度 */
    transform: translate(var(--initial-dx, 0), var(--initial-dy, 0)) scale(1);
    opacity: 0.9;
  }
  20% {
    opacity: 0.8; /* 稍微降低，更平滑 */
  }
  40% {
    opacity: 0.6;
  }
  60% {
    opacity: 0.4;
  }
  80% {
    opacity: 0.2;
  }
  100% {
    /* 继续扩散到最终位置 */
    transform: translate(calc(var(--initial-dx, 0) + var(--dx, 0)), calc(var(--initial-dy, 0) + var(--dy, 0))) scale(0.3);
    opacity: 0;
  }
}

