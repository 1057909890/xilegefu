/* 呼吸节奏编辑弹窗 */
.rhythm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 2000; /* 与其他弹窗保持一致 */
  padding: 40rpx;
  box-sizing: border-box;
}

.rhythm-modal.show {
  display: flex;
}

.rhythm-editor-content {
  width: 90%;
  max-width: 680rpx;
  max-height: 70vh; /* 限制最大高度，确保底部按钮区域可见 */
  background: rgba(30, 30, 69, 0.95);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  padding-bottom: 50rpx; /* 底部留出更多空间，确保按钮可见 */
  box-sizing: border-box;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.5);
  border:1px solid rgb(255 255 255 / 0.1);
  overflow-y: auto; /* 内容过多时可以滚动 */
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 10001; /* 确保内容在弹窗背景之上 */
  /* 确保滚动时按钮区域可见 */
  scroll-padding-bottom: 100rpx;
}

.editor-header {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
}

.editor-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.rhythm-editor-item {
  margin-bottom: 36rpx;
}

.editor-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.editor-label {
  font-size: 30rpx;
  color: #FFFFFF;
  flex-shrink: 0;
}

.editor-slider-wrapper {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.editor-slider-wrapper wx-slider{
  margin:0 !important;
}

.slider-labels-mini {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #D9D9D9;
}

.editor-value-display {
  font-size: 30rpx;
  color: #FFFFFF;
  flex-shrink: 0;
}

.editor-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  position: relative;
  z-index: 1; /* 确保按钮在最上层，可以点击 */
  flex-shrink: 0; /* 防止按钮被压缩 */
  padding-bottom: 20rpx; /* 底部留出空间 */
}

.editor-cancel-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  color: rgb(255 255 255 / 0.6);
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  padding: 0;
  position: relative;
  z-index: 10; /* 确保按钮可以点击 */
  pointer-events: auto; /* 确保可以点击 */
}

.editor-save-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(to right, rgb(34, 211, 238), rgb(59, 130, 246));
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  box-shadow: rgba(0, 0, 0, 0) 0px 0px 0px 0px, rgba(0, 0, 0, 0) 0px 0px 0px 0px, rgba(6, 182, 212, 0.2) 0px 10px 15px -3px, rgba(6, 182, 212, 0.2) 0px 4px 6px -2px;
  position: relative;
  z-index: 10; /* 确保按钮可以点击 */
  pointer-events: auto; /* 确保可以点击 */
}

/* 训练要点 */
.tips-section {
  background: #3C3B5E;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.tips-list {
