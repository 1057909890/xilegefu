}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #D9D9D9;
  line-height: 1.6;
}

/* 开始按钮 */
.start-btn-container {
  padding: 63rpx 0;
  padding-bottom: calc(63rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.start-btn {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: transparent;
  border: 4rpx solid #4FA5FF;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 60rpx rgba(79, 165, 255, 0.6), 
              0 0 120rpx rgba(79, 165, 255, 0.4),
              inset 0 0 40rpx rgba(79, 165, 255, 0.2);
  z-index: 1;
  padding: 0;
  margin: 0;
  overflow: visible;
  transition: all 0.3s;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  background: #472D44;
  border-color: #472D44;
  box-shadow: 0 0 40rpx rgba(71, 45, 68, 0.6);
}

.start-btn-glow {
  position: absolute;
  top: -30rpx;
  left: -30rpx;
  right: -30rpx;
  bottom: -30rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 165, 255, 0.4) 0%, transparent 70%);
  opacity: 0.8;
  animation: pulse 2s ease-in-out infinite;
  z-index: -1;
  filter: blur(20rpx);
}

.start-btn-glow::before {
  content: '';
  position: absolute;
  top: -50rpx;
  left: -50rpx;
  right: -50rpx;
  bottom: -50rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79, 165, 255, 0.2) 0%, transparent 70%);
  opacity: 0.6;
  animation: pulse 2s ease-in-out infinite;
  animation-delay: 0.5s;
  filter: blur(40rpx);
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.1);
    opacity: 1;
  }
}

.start-btn-text {
  font-size: 50rpx;
  font-weight: 400;
  color: #FFFFFF;
  position: relative;
  z-index: 2;
  letter-spacing: 0;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.6);
}

