  margin-bottom: 18rpx;
}

.binfo-bar {
  width: 6rpx;
  height: 34rpx;
  border-radius: 3rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.binfo-bar-blue  { background: #5EC8FF; }
.binfo-bar-green { background: #6EE7B7; }

.binfo-section-text {
  font-size: 34rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.3;
}

.binfo-card {
  background: rgba(255, 255, 255, 0.10);
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 14rpx;
}

.binfo-row-card {
  display: flex;
