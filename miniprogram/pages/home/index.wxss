.binfo-icon {
  font-size: 30rpx;
  line-height: 1;
}

.binfo-card-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.binfo-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.6;
}

.binfo-card-body {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.8;
}

.binfo-meta {
  font-size: 22rpx;
